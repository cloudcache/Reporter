    <script is:inline>
      const deck = document.getElementById("deck");
      const slides = Array.from(document.querySelectorAll("[data-slide]"));
      const links = Array.from(document.querySelectorAll("[data-slide-link]"));
      const dots = Array.from(document.querySelectorAll("[data-slide-dot]"));
      const setActive = (id) => {
        links.forEach((link) => link.classList.toggle("slide-nav-active", link.getAttribute("data-slide-link") === id));
        dots.forEach((dot) => dot.classList.toggle("slide-dot-active", dot.getAttribute("data-slide-dot") === id));
      };
      const observer = new IntersectionObserver((entries) => {
        const visible = entries.filter((entry) => entry.isIntersecting).sort((a, b) => b.intersectionRatio - a.intersectionRatio)[0];
        if (visible?.target?.id) setActive(visible.target.id);
      }, { root: deck, threshold: [0.55, 0.7, 0.9] });
      slides.forEach((slide) => observer.observe(slide));
      setActive("cover");
      window.addEventListener("keydown", (event) => {
        if (!["ArrowDown", "ArrowRight", "PageDown", "ArrowUp", "ArrowLeft", "PageUp"].includes(event.key)) return;
        const currentIndex = Math.max(0, slides.findIndex((slide) => slide.id === location.hash.replace("#", "")));
        const nextIndex = ["ArrowDown", "ArrowRight", "PageDown"].includes(event.key)
          ? Math.min(slides.length - 1, currentIndex + 1)
          : Math.max(0, currentIndex - 1);
        slides[nextIndex]?.scrollIntoView({ behavior: "smooth", block: "start" });
      });
    </script>
