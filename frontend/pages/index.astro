---
import AppLayout from "../layouts/AppLayout.astro"
import PageHeader from "../components/PageHeader.astro"
import { ScheduleOverview } from "../islands/ScheduleManager"

const stats = [
  { label: "患者总数", value: "1,234", hint: "较上月增长 12%" },
  { label: "本月随访", value: "56", hint: "待完成 23 例" },
  { label: "数据集", value: "8", hint: "活跃数据集" },
  { label: "表单模板", value: "15", hint: "已发布 9 个" },
]
---

<AppLayout>
  <PageHeader title="工作台" description="医疗研究患者管理、数据采集和报表概览" />
  <section class="grid gap-4 md:grid-cols-2 xl:grid-cols-4">
    {stats.map((stat) => (
      <article class="rounded-lg border border-line bg-surface p-4">
        <p class="text-sm text-muted">{stat.label}</p>
        <strong class="mt-3 block text-3xl font-semibold text-ink">{stat.value}</strong>
        <span class="mt-2 block text-xs text-muted">{stat.hint}</span>
      </article>
    ))}
  </section>
  <section class="mt-6 grid gap-4 lg:grid-cols-[1fr_1.2fr]">
    <article class="rounded-lg border border-line bg-surface p-5">
      <h2 class="text-base font-semibold">快速操作</h2>
      <div class="mt-4 grid gap-3">
        <a class="rounded-md border border-line px-4 py-3 hover:border-primary" href="/forms/design">创建采集表单</a>
        <a class="rounded-md border border-line px-4 py-3 hover:border-primary" href="/sources">配置外部数据源</a>
        <a class="rounded-md border border-line px-4 py-3 hover:border-primary" href="/data-center/reports">设计分析报表</a>
      </div>
    </article>
    <ScheduleOverview client:load />
  </section>
</AppLayout>
