---
interface Props {
  title: string
  description?: string
}
const { title, description } = Astro.props
---

<header class="mb-4 flex flex-wrap items-start justify-between gap-4">
  <div>
    <h1 class="text-2xl font-bold tracking-normal text-ink">{title}</h1>
    {description && <p class="mt-1 text-sm text-muted">{description}</p>}
  </div>
  <slot />
</header>
